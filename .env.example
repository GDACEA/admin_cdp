########################################
# GENERAL
########################################
APP_NAME=Gestion CDP
APP_BASE_URL=http://localhost:8519
APP_PORT=8519
APP_PAGE_ICON=images/favicon-32x32.png
APP_LOGO=images/LogoCDP.png
CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=120
CACHE_TTL_LONG=300

########################################
# STREAMLIT
########################################
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_PORT=8501

########################################
# POSTGRESQL
########################################
POSTGRES_DRIVER=postgresql+psycopg2
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
GDA_DATABASE=GDA
EQUIS_V2_DATABASE=EQUIS_V2
DATABASE_POOL_PRE_PING=true

########################################
# MICROSOFT ENTRA ID
########################################
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8519/auth/callback
ALLOWED_TENANT_ID=
ALLOWED_EMAIL_DOMAINS=cea.cl
AUTH_SESSION_MAX_AGE_SECONDS=3600
AUTH_STATE_MAX_AGE_SECONDS=600
MICROSOFT_AUTHORITY_BASE_URL=https://login.microsoftonline.com
# Permisos delegados requeridos en Entra ID: openid, profile, email y User.Read.
# MSAL solicita automáticamente los permisos OIDC al pedir User.Read.

########################################
# NAS / DATOS
########################################
NAS_PATH=/mnt/bd_historico
TECK_GROUPED_DATA_PATH=/mnt/bd_historico/TECK/096/data
TECK_OUTPUT_NAME=CreacionMasivaFichas

########################################
# SERVICIOS EXTERNOS
########################################
POWERBI_URL=
POWERBI_SCALE=0.60
POWERBI_IFRAME_HEIGHT=1680
ARCGIS_WORLD_IMAGERY_URL=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}

########################################
# DOCKER
########################################
PYTHON_IMAGE=python:3.11-slim
APP_WORKDIR=/app
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
DOCKER_IMAGE_NAME=admin-cdp
DOCKER_CONTAINER_NAME=admin-cdp
DOCKER_NETWORK=webapp_cdp_static_net
DOCKER_SUBNET=172.29.240.0/24
DOCKER_RESTART_POLICY=unless-stopped
